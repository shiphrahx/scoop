# Copy this file to .env.local and fill in real values from your Supabase project.
# Supabase dashboard: Project Settings -> Data API (URL) and API Keys (anon key).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key (Supabase dashboard -> API Keys). Server-only, never public.
# Used by /api/ingest/apple to resolve the per-user token and write activity.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Wearables provider. Legacy Fitbit registration closed in 2026; new apps use
# the Google Health API. Set HEALTH_PROVIDER=google to use it (anything else, or
# unset, keeps the legacy Fitbit path — only usable with an app registered before
# the cutoff, and only until ~Sept 2026).
HEALTH_PROVIDER=google

# Legacy Fitbit Web API app (dev.fitbit.com). Only for HEALTH_PROVIDER != google.
# Callback URL must be <your-site>/api/fitbit/callback.
FITBIT_CLIENT_ID=your-fitbit-client-id
FITBIT_CLIENT_SECRET=your-fitbit-client-secret

# Google Health API app (console.cloud.google.com -> enable "Google Health API",
# OAuth client type "Web application"). Used when HEALTH_PROVIDER=google. The
# authorized redirect URI must be <your-site>/api/fitbit/callback.
GOOGLE_HEALTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_HEALTH_CLIENT_SECRET=your-google-oauth-client-secret

# Shared secret for the scheduled Fitbit sync (/api/cron/fitbit). Vercel Cron
# sends it as "Authorization: Bearer <CRON_SECRET>". Any long random string.
CRON_SECRET=your-cron-secret

# 256-bit key that encrypts stored secrets at rest (Anthropic key, Fitbit
# tokens). Base64 or hex. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Keep it stable — rotating it makes existing encrypted rows unreadable.
SECRET_ENCRYPTION_KEY=your-base64-or-hex-32-byte-key
